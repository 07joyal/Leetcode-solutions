//LEETCODE-278
// Approach:Binary Search
// Time Complexity: O(log n)
// Space Complexity: O(1)

// The API isBadVersion is defined for you.
// bool isBadVersion(int version);


class Solution {
public:
    int firstBadVersion(int n) {
        int start=1,end=n; //starts at 1 and ends at nth version
        
        while(start<end)//binary search algorithm starts
        {
            int mid=start+(end-start)/2;
            if(isBadVersion(mid))
            {
                end=mid; //check the left side along withmidfor first occurence
            }
            else 
            {
                start=mid+1; //checks the right side
            }
        }
        return start; //returns the first bad occurence
        
    }
};
